opt_out_usage
default_platform(:ios)

# Valid deployment environments and their corresponding Flutter flavors
VALID_ENVS = ['dev', 'staging', 'prod'].freeze
ENV_TO_FLAVOR = {
  'dev' => 'dev',
  'staging' => 'staging',
  'prod' => 'prod'
}.freeze

# Helper method to validate and resolve environment to flavor
def resolve_env_to_flavor(env)
  unless VALID_ENVS.include?(env)
    UI.error("Invalid environment: #{env}")
    UI.user_error!("Environment must be one of: #{VALID_ENVS.join(', ')}")
  end

  ENV_TO_FLAVOR[env]
end

# Common lanes (available for all platforms)
desc "Setup IDE run configurations"
lane :setup_ide do
  idea_dir = "../.idea/runConfigurations"
  FileUtils.mkdir_p(idea_dir)

  configurations = {
    "Dev.xml" => "dev",
    "Staging.xml" => "staging",
    "Prod.xml" => "prod"
  }

  configurations.each do |filename, flavor|
    path = File.join(idea_dir, filename)
    content = generate_run_config(flavor)
    File.write(path, content)
    UI.success("✓ Generated #{path}")
  end

  UI.success("IDE configurations ready! Reload your IDE to see the new run configurations.")
end

desc "Configure environment variables (secrets/.env) - interactive"
lane :setup_env do
  env_path = "../secrets/.env"

  UI.header("Environment Configuration Setup")
  UI.message("This will create or update #{env_path}")
  UI.message("")

  # Prompt for TMDB API Key
  tmdb_key = prompt(text: "Enter TMDB API Key: ", secure_text: true)

  # Prompt for Backend URL
  backend_url = prompt(
    text: "Enter Backend URL (e.g., https://api.example.com): ",
    secure_text: false
  )

  write_env_file(tmdb_key: tmdb_key, backend_url: backend_url)

  UI.success("✓ Environment file created at #{env_path}")
  UI.success("Ready to build with: bundle exec fastlane ios build flavor:dev")
end

desc "Setup environment for CI builds (from environment variables)"
lane :setup_ci_env do
  tmdb_key = ENV["TMDB_API_KEY"]
  backend_url = ENV["BACKEND_URL"]

  unless tmdb_key && backend_url
    UI.error("Missing required environment variables")
    UI.user_error!("TMDB_API_KEY and BACKEND_URL must be set")
  end

  write_env_file(tmdb_key: tmdb_key, backend_url: backend_url)

  UI.success("✓ CI environment file created")
end

private_lane :write_env_file do |options|
  tmdb_key = options[:tmdb_key]
  backend_url = options[:backend_url]
  env_path = File.expand_path("..", Dir.pwd) + "/secrets/.env"
  FileUtils.mkdir_p(File.dirname(env_path))

  env_content = <<~ENV
    TMDB_API_KEY=#{tmdb_key}
    BACKEND_URL=#{backend_url}
  ENV

  File.write(env_path, env_content)
end

desc "Run code generation (build_runner) for all packages"
lane :codegen do
  root = File.expand_path("..", Dir.pwd)
  packages = Dir.glob("#{root}/**/pubspec.yaml")
    .select { |f| File.read(f).include?("build_runner") }
    .map { |f| File.dirname(f) }

  packages.each do |pkg|
    UI.message("Running build_runner in #{pkg}...")
    sh("cd #{pkg} && dart run build_runner build --delete-conflicting-outputs")
  end

  UI.success("Code generation complete for #{packages.size} packages")
end

desc "Run tests"
lane :test do |options|
  root = File.expand_path("..", Dir.pwd)
  report_dir = "#{root}/testResults"
  FileUtils.mkdir_p(report_dir)

  device = options[:device]
  cmd = "cd #{root} && flutter test --coverage --machine"
  cmd += " -d '#{device}'" if device
  cmd += " > #{report_dir}/flutter-test-results.json"

  sh(cmd)
  sh("cd #{root} && mv coverage/lcov.info #{report_dir}/lcov.info 2>/dev/null || true")
end

desc "Run linter (dart analyze)"
lane :lint do
  root = File.expand_path("..", Dir.pwd)
  sh("cd #{root} && flutter analyze")
end

desc "Clean iOS and Android build artifacts"
lane :clean do
  root = File.expand_path("..", Dir.pwd)
  UI.message("Cleaning build artifacts...")

  # Clean Dart/Flutter
  sh("cd #{root} && rm -rf build/ .dart_tool/")
  UI.success("✓ Removed build/ and .dart_tool/")

  # Clean iOS
  sh("cd #{root} && rm -rf ios/Pods/ ios/Podfile.lock")
  UI.success("✓ Removed ios/Pods/ and ios/Podfile.lock")

  # Clean Android
  sh("cd #{root} && rm -rf android/.gradle/")
  UI.success("✓ Removed android/.gradle/")

  # Reinstall dependencies
  UI.message("Reinstalling dependencies...")
  sh("cd #{root} && flutter pub get")
  UI.success("✓ Dependencies reinstalled")

  UI.success("✓ Cleanup complete! Ready to build.")
end

platform :ios do
  desc "Build iOS app for a given flavor"
  lane :build do |options|
    flavor = options[:flavor] || "dev"
    simulator = options[:simulator] == true || options[:simulator] == "true"
    root = File.expand_path("..", Dir.pwd)
    UI.message("Building iOS with flavor: #{flavor}#{simulator ? ' (simulator)' : ''}")
    cmd = "cd #{root} && flutter build ios --flavor=#{flavor} --dart-define-from-file=secrets/.env"
    cmd += " --simulator" if simulator
    sh(cmd)
  end

  desc "Deploy iOS to TestFlight"
  lane :deploy_testflight do |options|
    env = options[:env]
    root = File.expand_path("..", Dir.pwd)
    UI.user_error!("Environment is required. Use: fastlane ios deploy_testflight env:dev or env:prod") unless env

    flavor = resolve_env_to_flavor(env)
    dry_run = options[:dry_run].nil? || options[:dry_run] == true || options[:dry_run] == "true"

    if dry_run
      UI.important("🏃 DRY RUN MODE - No changes will be submitted")
    else
      UI.important("⚠️  PRODUCTION MODE - Submitting to TestFlight")
    end

    # Build IPA
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      derived_data_path: "build/ios",
      destination_generic_platform: "iOS",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.mobyle.moovie" => "AppStore"
        }
      },
      output_directory: "build/ios/ipa",
      output_name: "Runner.ipa"
    )

    if dry_run
      UI.success("✓ DRY RUN succeeded - IPA ready at build/ios/ipa/Runner.ipa")
    else
      # Upload to TestFlight
      api_key_id = ENV["APP_STORE_CONNECT_API_KEY_ID_#{env.upcase}"]
      api_key_issuer = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID_#{env.upcase}"]
      api_key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT_#{env.upcase}"]

      unless api_key_id && api_key_issuer && api_key_content
        UI.error("Missing App Store Connect API key for #{env} environment")
        UI.user_error!("Set APP_STORE_CONNECT_API_KEY_* environment variables")
      end

      # Write API key to file
      api_key_path = "#{root}/build/ios/authkey.p8"
      FileUtils.mkdir_p(File.dirname(api_key_path))
      File.write(api_key_path, api_key_content)

      begin
        upload_to_testflight(
          api_key_path: api_key_path,
          ipa: "build/ios/ipa/Runner.ipa",
          skip_waiting_for_build_processing: false,
          changelog: "#{env.capitalize} build from #{Time.now}"
        )

        UI.success("✓ iOS app uploaded to TestFlight successfully!")
      ensure
        # Clean up the temporary API key file
        File.delete(api_key_path) if File.exist?(api_key_path)
      end
    end
  end
end

platform :android do
  desc "Build Android app for a given flavor"
  lane :build do |options|
    flavor = options[:flavor] || "dev"
    root = File.expand_path("..", Dir.pwd)
    UI.message("Building Android with flavor: #{flavor}")
    sh("cd #{root} && flutter build appbundle --flavor=#{flavor} --dart-define-from-file=secrets/.env --release")
  end

  desc "Deploy Android to Google Play"
  lane :deploy_play do |options|
    env = options[:env]
    root = File.expand_path("..", Dir.pwd)
    UI.user_error!("Environment is required. Use: fastlane android deploy_play env:dev or env:prod") unless env

    flavor = resolve_env_to_flavor(env)
    dry_run = options[:dry_run].nil? || options[:dry_run] == true || options[:dry_run] == "true"

    if dry_run
      UI.important("🏃 DRY RUN MODE - No changes will be submitted")
    else
      UI.important("⚠️  PRODUCTION MODE - Submitting to Google Play Beta")
    end

    if dry_run
      UI.success("✓ DRY RUN succeeded - Build is ready for upload")
      UI.message("AAB location: build/app/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab")
    else
      # Get API key from environment
      api_json = ENV["GOOGLE_PLAY_API_JSON_#{env.upcase}"]
      unless api_json
        UI.error("Missing GOOGLE_PLAY_API_JSON_#{env.upcase} environment variable")
        UI.user_error!("Set GOOGLE_PLAY_API_JSON_* environment variables")
      end

      # Write API JSON to temp file
      api_json_path = "#{root}/build/android/google-play-api.json"
      FileUtils.mkdir_p(File.dirname(api_json_path))
      File.write(api_json_path, api_json)

      begin
        # Upload to Google Play
        upload_to_play(
          json_key: api_json_path,
          aab: "build/app/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab",
          track: 'beta',
          skip_upload_apk: true,
          skip_upload_images: true,
          skip_upload_screenshots: true,
          release_status: 'draft'
        )

        UI.success("✓ Android app uploaded to Google Play Beta successfully!")
      ensure
        # Clean up the temporary API key file
        File.delete(api_json_path) if File.exist?(api_json_path)
      end
    end
  end
end

# Helper method to generate run configuration XML
def generate_run_config(flavor)
  <<~XML
    <component name="ProjectRunConfigurationManager">
      <configuration default="false" name="#{flavor.capitalize}" type="FlutterRunConfigurationType" factoryName="Flutter">
        <option name="additionalArgs" value="--flavor #{flavor} --dart-define-from-file=secrets/.env" />
        <option name="filePath" value="$PROJECT_DIR$/lib/main.dart" />
        <method v="2" />
      </configuration>
    </component>
  XML
end
