platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug-dev' => :debug,
  'Debug-staging' => :debug,
  'Debug-prod' => :debug,
  'Release-dev' => :release,
  'Release-staging' => :release,
  'Release-prod' => :release,
  'Profile-dev' => :release,
  'Profile-staging' => :release,
  'Profile-prod' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Clean up generic Debug and Release xcconfigs since they're unused
  debug_xcconfig = File.join(__dir__, 'Flutter', 'Debug.xcconfig')
  release_xcconfig = File.join(__dir__, 'Flutter', 'Release.xcconfig')

  File.write(debug_xcconfig, "#include \"Generated.xcconfig\"\n") if File.exist?(debug_xcconfig)
  File.write(release_xcconfig, "#include \"Generated.xcconfig\"\n") if File.exist?(release_xcconfig)

  # Set base configurations for Runner target build configs
  runner_project = Xcodeproj::Project.open('Runner.xcodeproj')
  runner_target = runner_project.targets.select { |t| t.name == 'Runner' }.first

  if runner_target
    # Map build configurations to their xcconfig files
    config_map = {
      'Debug-dev' => 'Flutter/Debug-dev.xcconfig',
      'Debug-staging' => 'Flutter/Debug-staging.xcconfig',
      'Debug-prod' => 'Flutter/Debug-prod.xcconfig',
      'Release-dev' => 'Flutter/Release-dev.xcconfig',
      'Release-staging' => 'Flutter/Release-staging.xcconfig',
      'Release-prod' => 'Flutter/Release-prod.xcconfig',
      'Profile-dev' => 'Flutter/Profile-dev.xcconfig',
      'Profile-staging' => 'Flutter/Profile-staging.xcconfig',
      'Profile-prod' => 'Flutter/Profile-prod.xcconfig',
    }

    runner_project.build_configuration_list.build_configurations.each do |config|
      if config_map[config.name]
        # Find or create the file reference
        file_ref = runner_project.files.select { |f| f.real_path.to_s.end_with?(config_map[config.name]) }.first
        unless file_ref
          file_ref = runner_project.new_file(config_map[config.name])
        end
        config.base_configuration_reference = file_ref
      else
        # Clear base config for non-flavor configs (Debug, Release)
        config.base_configuration_reference = nil
      end
    end

    runner_project.save
  end
end
